{
  "entities": {
    "Integration": {
      "title": "Integration",
      "description": "Configuration for an external API integration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "provider": { "type": "string", "enum": ["gemini", "openai", "anthropic", "custom"] },
        "apiKey": { "type": "string" },
        "endpoint": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "disabled", "error"] },
        "lastUsed": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "provider", "status"]
    },
    "ApiLog": {
      "title": "API Log",
      "description": "Log of an API call for monitoring",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "service": { "type": "string" },
        "status": { "type": "integer" },
        "responseTime": { "type": "integer" },
        "error": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["timestamp", "service", "status"]
    },
    "AdminProfile": {
      "title": "Admin Profile",
      "description": "Profile of an application administrator",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "editor"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "SystemConfig": {
      "title": "System Configuration",
      "description": "Global settings for the application and its modules",
      "type": "object",
      "properties": {
        "activeStudios": { "type": "array", "items": { "type": "string" } },
        "maintenanceMode": { "type": "boolean" },
        "allowNewRegistrations": { "type": "boolean" },
        "version": { "type": "string" },
        "updatedBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["activeStudios"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Profile of a neural node unit",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "GlobalHistoryItem": {
      "title": "Global History Item",
      "description": "Neural generation memory",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["image", "audio", "video", "text"] },
        "studio": { "type": "string" },
        "content": { "type": "string" },
        "prompt": { "type": "string" },
        "metadata": { "type": "object" }
      }
    },
    "AIModel": {
      "title": "AI Model",
      "description": "Definition of an AI model available in the system",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "provider": { "type": "string", "enum": ["google", "openai", "anthropic", "custom"] },
        "modelId": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "isFree": { "type": "boolean" },
        "costPerCall": { "type": "number" },
        "studios": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "deprecated", "maintenance"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A creative project in the Nexus",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "studioType": { "type": "string" },
        "status": { "type": "string" },
        "progress": { "type": "number" },
        "priority": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SmartAsset": {
      "title": "Smart Asset",
      "description": "An asset with AI-powered metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "aiDescription": { "type": "string" },
        "isFavorite": { "type": "boolean" },
        "studioSource": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "AssistantSession": {
      "title": "Assistant Session Message",
      "description": "A message in the assistant neural link",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant", "model", "system"] },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "context": { "type": "string" },
        "modelUsed": { "type": "string" }
      }
    }
  },
  "firestore": {
    "vault_assets": {
      "schema": "SmartAsset",
      "description": "AI-powered asset library nodes"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Creative projects for creators"
    },
    "/assistant_sessions/{messageId}": {
      "schema": "AssistantSession",
      "description": "Neural assistant link history"
    },
    "/integrations/{integrationId}": {
      "schema": "Integration",
      "description": "External API endpoints and keys"
    },
    "/apiLogs/{logId}": {
      "schema": "ApiLog",
      "description": "Performance and error logs for API calls"
    },
    "/admins/{adminId}": {
      "schema": "AdminProfile",
      "description": "List of authorized administrators"
    },
    "/system_config/{configId}": {
      "schema": "SystemConfig",
      "description": "Global application state and module control"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Neural population nodes"
    },
    "/history/{historyId}": {
      "schema": "GlobalHistoryItem",
      "description": "Neural generation memories"
    },
    "/models/{modelId}": {
      "schema": "AIModel",
      "description": "Available AI models and their studio mappings"
    }
  }
}
